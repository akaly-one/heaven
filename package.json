{
  "name": "heaven",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@heaven/web",
    "dev:cp": "turbo run dev --filter=@heaven/cp",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@heaven/web",
    "build:cp": "turbo run build --filter=@heaven/cp",
    "lint": "turbo run lint",
    "start:web": "turbo run start --filter=@heaven/web",
    "start:cp": "turbo run start --filter=@heaven/cp"
  },
  "devDependencies": {
    "turbo": "^2.5.8",
    "typescript": "^5"
  },
  "packageManager": "npm@10.0.0"
}
