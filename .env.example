# ═══════════════════════════════════════════════════════════════════
# Heaven — Environment variables template
# Toute env var utilisée dans `src/` DOIT apparaître ici (placeholder OK).
# Vérifié automatiquement par `scripts/check-env.mjs` pré-push et CI.
# ═══════════════════════════════════════════════════════════════════

# ─── Supabase (projet dédié Heaven)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin
ADMIN_SECRET=                      # Secret admin HMAC

# ─── Auth JWT
HEAVEN_JWT_SECRET=
HEAVEN_SYNC_SECRET=                # Secret sync inter-CP

# ─── Cloudinary (médias)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ─── SQWENSY OS (tunnel interne discret — pas d'exposition publique)
SQWENSY_OS_API_URL=https://sqwensy.com
SQWENSY_SYNC_URL=
SQWENSY_TUNNEL_KEY=
SQWENSY_URL=
SQWENSY_API_KEY=                   # API key server-to-server (model-profiles, messaging, media, photo)
OS_BEACON_URL=
NEXT_PUBLIC_SQWENSY_CONFIGURED=    # Flag UI (bool), jamais d'URL publique

# ─── Automation (n8n / cron jobs internes)
AUTOMATION_API_KEY=                # Secret partagé avec n8n pour endpoints /api/agence/media/sync
CRON_SECRET=                       # Bearer secret for manual /api/cron/* triggers (Vercel Cron auto-auths via x-vercel-cron header)

# ─── IA (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ─── Instagram AI Agent (YUMI @yumiiiclub)
# Tokens sensibles stockés aussi en DB (instagram_config) — server-only usage.
INSTAGRAM_AGENT_ENABLED=false
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_DEFAULT_MODE=review        # review (draft for admin approval) | auto | shadow
META_APP_ID=
META_APP_SECRET=                     # From https://developers.facebook.com/apps/<APP_ID>/settings/basic/
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=              # Short-lived by default (1h) — exchange via /api/instagram/exchange-token for 60d
META_VERIFY_TOKEN=                   # Any string you choose — set same value in Meta Webhook config

# ═══ PAYMENT PROVIDERS ═══

# ─── PayPal (sandbox → live when ready)
PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# Default: https://api-m.sandbox.paypal.com (change to https://api-m.paypal.com for live)
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# ─── Revolut (sandbox → live when ready)
REVOLUT_API_SECRET_KEY=
REVOLUT_WEBHOOK_SECRET=
# Default: https://sandbox-merchant.revolut.com (change to https://merchant.revolut.com for live)
REVOLUT_API_URL=https://sandbox-merchant.revolut.com
NEXT_PUBLIC_REVOLUT_CONFIGURED=
NEXT_PUBLIC_REVOLUT_ENABLED=

# ─── Stripe (BRIEF-16 — DÉSACTIVÉ par défaut, urgence only)
# TOS adult content ban quasi-certain → ne jamais activer sauf indisponibilité totale PayPal+Revolut
# Laisser vide ou "false". Passer à "true" SEULEMENT en urgence ponctuelle.
ALLOW_STRIPE=

# ─── Wise Business — Payment Requests API (BRIEF-16 Phase C)
# Compte Wise Business (KYB obligatoire) — créer API token sur wise.com/settings/apitokens
# Profile ID = ton business profile Wise (GET /v2/profiles pour lister)
WISE_API_TOKEN=
WISE_BUSINESS_PROFILE_ID=
# Default: https://api.wise.com (sandbox : https://api.sandbox.transferwise.tech)
WISE_API_URL=https://api.wise.com

# ─── PostHog (free tier EU — silo Heaven, projet dédié)
# 100k errors + 1M events + 5k session replay + feature flags inclus
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── AI Agent (NB 2026-04-24)
# Groq Cloud (free tier 14400 req/jour Llama 3.3 70B) — console.groq.com
GROQ_API_KEY=
# Override model default llama-3.3-70b-versatile
GROQ_MODEL=
# Set to "true" en prod pour désactiver /api/dev/*
DISABLE_DEV_ENDPOINTS=

# ─── Instagram Graph API (Meta)
# Page Access Token — requis pour sendInstagramReply + sync-instagram cron
INSTAGRAM_PAGE_ACCESS_TOKEN=

# ─── BRIEF-13 Verification flow self-validation IP-matched
# Salt pour hasher IP subnet /24 + User-Agent (RGPD friendly)
# Générer avec : openssl rand -base64 32
VERIFICATION_SALT=

# ─── Site URL (pour liens /verify/[token] et autres generators)
# Default : https://heaven-os.vercel.app
NEXT_PUBLIC_SITE_URL=
